void compression(String text){
  int a = 0;
  int b = 0;
  int c = 0;
  
  for(int i = 0; i < text.length; i++){
    if(text[i] == 'a'){
      a++;
    }
    else if(text[i] == 'b'){
      b++;
    }
    else if(text[i] == 'c'){
      c++;
    }
    
  }
  print("a$a b$b c$c");
}
void main(){
  compression('aacvbdcba');
}
