List<String> longWord(String text){
  List<String> words = text.trim().split(RegExp(r'\s+'));
  List<String> longest = [""];
  int maxLength = 0;
  
  for(int i = 0; i <words.length; i++){
    if(words[i].length > maxLength){
      maxLength = words[i].length;
      longest.add(words[i]);
    }
    else if(words[i].length == maxLength){
      longest.add(words[i]);
    }
  }
  return longest;
}
void main(){
  print(longWord("flutter shohanu coding"));
}
