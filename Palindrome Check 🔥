
bool isPalindrome(String text) {
  int flag = 0;

  for (int i = 0; i < text.length; i++) {
    for (int j = text.length - 1; j >= 0; j--) {
      if (text[i] == text[j]) {
        flag = 0;
      } else if (text[i] != text[j]) {
        flag = 1;
      }
    }
  }
  if (flag == 0) {
    return true;
  }
  return false;
}

void main() {
  if (isPalindrome('madam') == true) {
    print('This is palindrome');
  } else {
    print('This is not palindrome');
  }
}
