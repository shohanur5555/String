String longWord(String text){
  List<String> words = text.trim().split(RegExp(r'\s+'));
  String longest = "";
  
  for(int i = 0; i < words.length; i++){
    if(longest.length < words[i].length){
      longest = words[i];
    }
  }
  return longest;
}

void main(){
  print(longWord("I Love flutter programing"));
}
